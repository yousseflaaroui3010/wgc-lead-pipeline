# Copy to infra/.env on the VPS. NEVER commit the real file (.gitignore'd).

# REQUIRES-HUMAN-AUTHORIZATION: generate once (`openssl rand -hex 32`), back
# up offline. Losing it bricks every credential stored in n8n.
N8N_ENCRYPTION_KEY=

# Render-token HMAC key (ADR-2). `openssl rand -hex 32`.
# REQUIRES-HUMAN-AUTHORIZATION to rotate once live.
WGC_HMAC_SECRET=

# Random webhook path segment (TD-3). `openssl rand -hex 8`. Must match the
# imported workflow paths and nginx snippets/hook_id.conf.
WGC_HOOK_ID=

# LeadSimple REST key — leave empty until Jon's admin creates it; the
# email-parse path is primary until then (G-2).
LEADSIMPLE_API_KEY=

# LeadSimple per-Source email-parse address (from the Source settings page).
PARSE_ADDRESS=

# Lead notifications (FR-6): Jon, Ashley, Youssef — comma-separated.
NOTIFY_EMAILS=

# Ops alerts (WF-3): Youssef.
ALERT_EMAIL=

# Sender identity on the transactional SMTP relay (S3-D3: never local postfix).
MAIL_FROM=
